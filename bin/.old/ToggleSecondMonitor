#!/bin/bash

MONITOR="DP-4"
PRIMARY="HDMI-0"
STATUS=$(xrandr | grep "$MONITOR connected" | grep -v disconnected)

if echo "$STATUS" | grep -q "$MONITOR connected"; then
  if echo "$STATUS" | grep -q "[0-9]x[0-9]"; then
    # If monitor is active, turn it off
    xrandr --output "$MONITOR" --off
  else
    # If monitor is connected but inactive, turn it on
    xrandr --output "$MONITOR" --auto --left-of "$PRIMARY"
  fi
fi
