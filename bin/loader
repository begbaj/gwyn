#!/usr/bin/env bash
set -euo pipefail

# Load all functions from loadlogic directory
for file in "$HOME"/.config/bspwm/bin/loadlogic/*.sh; do
  [ -f "$file" ] && source "$file"
done

# Wait for a process to terminate
term_wait() {
  local process_name=$1
  while pgrep -f "$process_name" >/dev/null 2>&1; do
    sleep 0.2
  done
}

# Stop running UI components before applying a new theme
stop_all() {
  if pgrep -x polybar >/dev/null 2>&1; then
    polybar-msg cmd quit >/dev/null 2>&1 || true
    term_wait "polybar"
  fi

  if pgrep -f "eww.*bar" >/dev/null 2>&1; then
    pkill -f "eww.*bar" || true
    term_wait "eww.*bar"
  fi

  if pgrep -f "bspc subscribe node_state" >/dev/null 2>&1; then
    pkill -f "bspc subscribe node_state" || true
    term_wait "bspc subscribe node_state"
  fi

  if pgrep -x xwinwrap >/dev/null 2>&1; then
    pkill xwinwrap || true
    term_wait "xwinwrap"
  fi

  if [[ -f /tmp/wall_refresh.pid ]]; then
    kill "$(cat /tmp/wall_refresh.pid)" 2>/dev/null || true
    rm -f /tmp/wall_refresh.pid
  fi
}

# Load theme configuration
source "$HOME/.config/bspwm/themes/$THEME_NAME/config.sh"

# config.sh should tell which components to load with theme specific configuration
