###############
# launchers
###############

super + ctrl + alt + l
	slock

super + Return
	alacritty

super + p
  rofi -show drun -theme "$HOME"/.config/bspwm/src/rofi-themes/Launcher.rasi

super + Print
	flameshot gui

###############
# category: macros
###############
#
super + shift + c
  xcrop $(xdotool getactivewindow)

###############
# category: system
###############

# name: Reload Keybindings
# comb: super + escape
super + Escape
	pkill -USR1 -x sxhkd; dunstify -u low -i ~/.config/bspwm/src/assets/reload.svg 'sxhkd' 'The configuration file has been reloaded successfully!'

# name: quit/restart bspwm
# comb: super + ctrl + shift + r
super + ctrl + shift + r
	bspc wm -r; pkill -USR1 -x sxhkd;

# name: desktop management like dwm
# comb: super + 1-9
# combdesc: switch to desktop
# comb: super + shift + 1-9
# combdesc: move focused node to desktop
super + {_,shift + }{1-9}
    bspc {desktop -f,node -d} 'pointed:^{1-9}'

###############
# category: bspwm hotkey
###############

super + ctrl + shift + Escape
	bspc quit

# close and kill
super + {shift +, shift + ctrl +}q
	bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window

# Hide/Unhide Window
# ctrl + alt + h
# 	BspHideNode

###############
# state/flags
###############

# set the window state
super + shift + {space,f,t}
	bspc node focused -t {\~floating,\~fullscreen, tiled}

# set the node flags
super + shift + {m,x,0,z}
	bspc node focused -g {marked,locked,sticky,private}

###############
# focus/swap
###############

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node {-f,-s} {west,south,north,east}.!hidden.window

# focus/swap the next/previous window in the current desktop
# super + {_,shift + }{j,k}
# 	bspc node {-f,-s} {next,prev}.local.!hidden.window

# switch monitor focus
super + s
	bspc monitor {-f} last

super + shift + s
	bspc node -m last; 	bspc monitor {-f} last

super + d
	bspc monitor {-f} east

super + shift + d
	bspc node -m east; 	bspc monitor {-f} east

super + a
	bspc monitor {-f} west

super + shift + a
	bspc node -m west; 	bspc monitor {-f} west

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

super + e
	bspc node '@parent.vertical' -y horizontal \
	    || bspc node '@parent' -y vertical

super + shift + e
	bspc node '@/' -R 90

###############
# preselect
###############

# preselect the direction
super + alt + {h,j,k,l}
	bspc node -p {west,south,north,east}
#
# # preselect the ratio
super + alt + {1-9}
	bspc node -o 0.{1-9}
#
# # cancel the preselection for the focused node
super + alt + space
	bspc node -p cancel
#
# # cancel the preselection for the focused desktop
# super + ctrl + shift + space
# 	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

###############
# move/resize
###############

# expand a window by moving one of its side outward
super + ctrl + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + ctrl + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

