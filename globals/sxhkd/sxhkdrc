# Brightness control
XF86MonBrightnessUp
  brightnessctl set +10%

XF86MonBrightnessDown
  brightnessctl set 10%- 

# Volume control
XF86Audio{RaiseVolume,LowerVolume,Mute}
	sh "$HOME"/.config/bspwm/bin/.old/Volume { --inc, --dec, --toggle}

# Music Control
XF86Audio{Next,Prev,Play,Stop}
	sh "$HOME"/.config/bspwm/bin/.old/MediaControl {--next,--previous,--toggle,--stop}

