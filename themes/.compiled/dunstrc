[global]
    monitor = a
    follow = mouse
    width = 300
    height = 300
    origin = top-right
    offset = 15x45
    shrink = no
    padding = 10
    horizontal_padding = 10
    gap_size = 5
    transparency = 15
    frame_width = 2
    frame_color = "#ffffff"
    corner_radius = 8
    corners = all
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    font = "Sans 10"
    alignment = center
    vertical_alignment = center
    line_height = 0
    format = "<span weight='bold' size='xx-large'>%s</span>\n%b"
    markup = full
    notification_limit = 5
    indicate_hidden = yes
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    ignore_newline = no
    ignore_dbusclose = false
    default_pause_level = 0
    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    history_length = 20
    enable_posix_regex = true
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1A1B26"
    foreground = "#BDC7D3"
    frame_color = "#1A1B26"
    timeout = 5

[urgency_normal]
    background = "#1A1B26"
    foreground = "#BDC7D3"
    frame_color = "#1A1B26"
    timeout = 10

[urgency_critical]
    background = "#FF2233"
    foreground = "#BDC7D3"
    frame_color = "#FF2233"
    timeout = 0
    override_pause_level = 1

