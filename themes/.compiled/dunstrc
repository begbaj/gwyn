[global]
    background = "#282c34CC"
    frame_color = "#ffffff33"

    monitor = 0
    follow = mouse
    width = 600
    height = 350
    origin = top-right
    offset = 15x45
    shrink = no
    padding = 10
    horizontal_padding = 10
    gap_size = 5
    transparency = 15
    frame_width = 2
    frame_color = "#F2F4F8"
    corner_radius = 8
    corners = all
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    font = "Sans 10"
    alignment = left
    vertical_alignment = left
    line_height = 0
    format = "<span weight='bold' size='x-large'>%s</span>\n%b"
    markup = full
    notification_limit = 5
    indicate_hidden = yes
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    ignore_newline = no
    ignore_dbusclose = false
    default_pause_level = 0
    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 32
    history_length = 20
    enable_posix_regex = true
    mouse_left_click = do_action
    mouse_middle_click = close_current
    mouse_right_click = 

[urgency_low]
    background = "#666C"
    foreground = "#F2F4F8"
    frame_color = "#6665"
    timeout = 5

[urgency_normal]
    background = "#666C"
    foreground = "#F2F4F8"
    frame_color = "#6665"
    timeout = 10

[urgency_critical]
    background = "#FF2233CC"
    foreground = "#F2F4F8"
    frame_color = "#FF2233"
    timeout = 0
    override_pause_level = 1

